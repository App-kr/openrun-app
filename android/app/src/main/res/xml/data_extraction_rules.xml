<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ 데이터 추출 규칙 (android:dataExtractionRules)
    유효 domain: file | database | sharedpref | external | root
    disableIfNoEncryptionCapabilities: 암호화 불가 기기엔 클라우드 백업 비활성화
-->
<data-extraction-rules>

    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <!-- Firebase 토큰 제외 -->
        <exclude domain="sharedpref"
            path="com.google.firebase.installations.api.json"/>
        <!-- 로컬 DB 제외 -->
        <exclude domain="database" path="taekit.db"/>
        <exclude domain="database" path="taekit_notifications.db"/>
    </cloud-backup>

    <device-transfer>
        <!-- 기기간 전송 시에도 DB/토큰 제외 -->
        <exclude domain="sharedpref"
            path="com.google.firebase.installations.api.json"/>
        <exclude domain="database" path="taekit.db"/>
        <exclude domain="database" path="taekit_notifications.db"/>
    </device-transfer>

</data-extraction-rules>
