<?xml version="1.0" encoding="utf-8"?>
<!--
    네트워크 보안 설정 — Play Store 필수
    - HTTPS 전용 (cleartext HTTP 완전 차단)
    - 디버그 빌드에서만 로컬호스트 허용
    - 인증서 핀닝 불필요 (Render/Cloudflare CDN 사용 중)
-->
<network-security-config>

    <!-- 기본 정책: HTTPS 전용, cleartext 금지 -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- 시스템 CA 인증서만 신뢰 -->
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- 디버그 전용: 로컬 에뮬레이터/개발 서버 허용 -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>

</network-security-config>
